                <div class="flex gap-5 mt-12">
                    <a href="{{ restaurant.iosLink }}" target="_blank"  class="hover:cursor-pointer"><img class="w-52" src="/images/Apple-Play-icon.png"></a>
                    <a href="{{ restaurant.androidLink }}" target="_blank"  class="hover:cursor-pointer"><img class="w-52" src="/images/Google-Play-icon.png"></a>
