{# mobile app download seciton #}

<section id="download_app" class="">
    <div class="max-w-screen-xl mx-auto w-full px-6 py-16">
        <div class="download-app-wrapper flex flex-col md:flex-row md-flex-wrap gap-14">
            <div class="app-image text-center">
                <img class="w-96 md:w-[600px] block mx-auto" src="{{ restaurant.downloadAppImage }}" alt="mobile-app-image">
            </div>
            <div class="app-content flex flex-col items-center justify-center md:pl-5 md:items-start">
