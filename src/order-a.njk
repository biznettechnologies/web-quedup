---
layout: base
title: Order
description: add seo description
tags: order_page
order: 2
eleventyNavigation:
  key: Order From A
  parent: Order
---

<section>
  <div class="max-w-screen-xl mx-auto w-full px-3 py-16">

    <div id='zuppler-menu'
    role="main"
    data-channel-url="http://api.zuppler.com/v3/channels/mychiangmaicuisine.json"
    data-integration='chiangmai'
    data-restaurant-id='116'
    data-prices="range"
    data-app-url="/order-a"
    data-menu="compact"

    data-portal2-cuisines-url="https://zuppler-static.netlify.app/cuisines"
    data-portal2-cuisines-extension="png"
    data-portal-dp="Gluten Free, Low Calorie, Low Sodium, Low Sugar, Nut Free, Organic, Sugar Free, Vegan, Vegetarian"
    data-portal-restore-last-location="no"
    
    data-colors-background='#ffffff'
    data-colors-highContrast='#000000'
    data-colors-midContrast='#333333'
    data-colors-lowContrast='#999999'
    data-colors-brand='#7f4bc3'
    data-colors-heroBackground='#9e5375'
    data-colors-heroContrast='#FFFFFF'
    data-fonts-heading='Open Sans Condensed, helvetica, sans-serif'
    data-fonts-body='Roboto, helvetica, sans-serif'
    data-fonts-deco='Montserrat, helvetica, sans-serif'>

      {% edge %}

      {% macro item(i) %}
        <li class="p-2 border-solid border-slate-400 border">
          <p class="text-lg">{{ i.name }}</p>
          <span class='item-description'>{{ i.description }}</span>
        </li>
      {% endmacro %}

      {% macro category(c) %}
        <h3 class="text-2xl font-bold">{{ c.name }}</h3>
        <ul class="grid grid-cols-2 md:grid-cols-3 gap-3">
          {% for i in c.items %}
            {{ item(i) }}
          {% endfor %}
      </ul>
    {% endmacro %}

    {% macro menu(m) %}
      <h2 class="text-3xl font-bold">{{ m.name }}</h2>
      {% for c in m.categories %}
        {{ category(c) }}
      {% endfor %}
    {% endmacro %}

    {% if appData.restaurantInfo %}
      <h1>{{appData.restaurantInfo.name | safe}}</h1>
      <p>Cuisines: {{appData.restaurantInfo.cuisines}}</p>
      <p>Address: {{appData.restaurantInfo.locations[0].address.nickname}}</p>
    {% endif %}

    {% if appData.menus %}
      {% for m in appData.menus %}
        {{ menu(m) }}
      {% endfor %}
    {% endif %}

    {% if appData.restaurants %}
      <div class="flex flex-col items-center justify-center pt-10">
        <h1>Restaurants</h1>
        {% for r in appData.restaurants %}
          <div>
             <a href="/index/restaurants/{{r.integrations[0].remote_id}}/{{r.id}}">
              <strong>{{ r.name | safe }}</strong> - {{r.locations[0].address.nickname}} - {{r.cuisines}}
            </a>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% endedge %}

  </div>
  <script>
    zupplerBridge = null

    function initZupplerBridge(api) {
      zupplerBridge = api
      api.addIntegrationStateListener(onIntegrationChanged)
      return Promise.resolve(true)
    }
    function onIntegrationChanged(type, params) {
      console.log("BSDBG: integrationChanged", type, params)
      if (type === "menu:view" || type === "item:view") {
        document.title = "{{ site.name }} - Order " + params.name
      }
    }
  </script>
  <script type="text/javascript" src="//web5.zuppler.com/common.js"></script>
  <script type="text/javascript" src="//web5.zuppler.com/order.js"></script>

</div>
</section>