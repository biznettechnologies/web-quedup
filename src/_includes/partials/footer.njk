<footer class="bg-black text-white">
  <div class="max-w-screen-xl mx-auto w-full px-6 py-16">
    <div class="footer_info_wrapper md:flex md:flex-row md:flex-wrap gap-8 flex flex-col">
      <div class="flex-1">
        <div class="hours">
          <h3 class="text-xl md:text-3xl mb-4 font-bold">Hours</h3>
          <p class="text-sm md:text-lg mb-3">
            <strong>Sun - Sat:</strong> 11:00 am - 9:00 pm</p>
          <p class="text-sm md:text-lg mb-3">
            <strong>Mon:</strong> Closed
            </p>
        </div>
      </div>
      <div class="flex-1">
        <div class="contact">
          <h3 class="text-xl md:text-3xl mb-4 font-bold">Contact</h3>
          <p class="text-sm md:text-lg mb-3">
            <strong>Address:</strong>
            {{ restaurant.address }}
          </p>
          <p class="text-sm md:text-lg mb-3">
            <strong>Phone:</strong>
            <a href="tel:{{ restaurant.phone }}">{{ restaurant.phone }}</a>
          </p>
        </div>
      </div>
      <div class="flex-1 hidden md:block">
        <div class="map">
          <iframe
          class="rounded-2xl"
              src="{{ restaurant.googleMapembedUrl }}"
              width="100%"
              height="250"
              style="border: 0"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
        </div>
      </div>
    </div>
    <hr class="hidden md:block md:my-10">
    <div class="flex flex-col-reverse md:flex-row md:flex-wrap md:justify-between md:items-center gap-10">
      <div class="socials flex gap-5 items-center">
        <a target="_blank" href="{{ restaurant.facebook }}" class="flex items-center"><img class="w-8" src="/images/facebook.png"></a>
        <a target="_blank" href="{{ restaurant.instagram }}" class="flex items-center"><img class="w-8" src="/images/instagram.png"></a>
        <a target="_blank" href="{{ restaurant.twitter }}" class="flex items-center"><img class="w-8" src="/images/twitter.png"></a>
        <a target="_blank" href="{{ restaurant.yelp }}" class="flex items-center"><img class="w-8" src="/images/yelp.png"></a>
        <a target="_blank" href="{{ restaurant.tripadvisor }}" class="flex items-center"><img class="w-8" src="/images/tripadvisor.png"></a>
        
      </div>
      <div class="mobile-nav flex flex-col items-start md:flex-row md:items-center uppercase">
        <a href="/{{ restaurant.urlCuisine }}-food-order-online" class="btn-primary mt-5 md:mt-0">Order Now</a>
      </div>
    </div>
    <div class="copyright mt-8">
      <p class="text-xs">© 2024 All rights reserved.</p>
    </div>
  </footer>